    "/api/search-shipment": {
      "post": {
        "tags": ["Shipments"],
        "summary": "Search shipments",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Provide any one of 'reference_number', 'customer_name', or 'contact_number' to search for a shipment. Only one of these is required per search.",
                "properties": {
                  "reference_number": { "type": "string", "description": "Shipment reference number" },
                  "customer_name": { "type": "string", "description": "Receiver/customer name" },
                  "contact_number": { "type": "string", "description": "Receiver/contact phone number" },
                  "user_type": { "type": "string", "example": "admin or user", "description": "User role for access control" },
                  "user_id": { "type": "string", "description": "User ID (required if user_type is 'user')" }
                },
                "anyOf": [
                  { "required": ["reference_number"] },
                  { "required": ["customer_name"] },
                  { "required": ["contact_number"] }
                ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Shipments search result" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
